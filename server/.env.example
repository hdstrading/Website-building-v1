# Copy to .env for local runs. On a host, set these as environment variables.
PORT=3000

# REQUIRED in production: a long random string used to sign login sessions.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# First-run Super Admin (created only if no Super Admin exists yet).
SUPERADMIN_EMAIL=admin@yourcompany.com
SUPERADMIN_PASSWORD=change-this-strong-password

# Where the SQLite database file is stored (use a persistent disk in production).
DATA_DIR=./data

NODE_ENV=production

# Public URL of the site (used in email links). If unset, derived from requests.
# PUBLIC_URL=https://payroll.yourcompany.com

# Email (optional) — enables payslip-ready notifications and self-service
# password reset. Leave SMTP_HOST blank to disable email features entirely.
# Example for a typical provider:
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@yourcompany.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=PH Payroll <notifications@yourcompany.com>

# Used only by docker-compose (Caddy reverse proxy / automatic HTTPS).
#   - Set to your domain for HTTPS, e.g.  SITE_ADDRESS=payroll.yourcompany.com
#   - Or ":80" to serve plain HTTP for a quick test without a domain.
SITE_ADDRESS=payroll.yourcompany.com
