# Copy to .env for local runs. On a host, set these as environment variables.
PORT=3000

# REQUIRED in production: a long random string used to sign login sessions.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# First-run Super Admin (created only if no Super Admin exists yet).
SUPERADMIN_EMAIL=admin@yourcompany.com
SUPERADMIN_PASSWORD=change-this-strong-password

# Where the SQLite database file is stored (use a persistent disk in production).
DATA_DIR=./data

NODE_ENV=production
